# Albayan Manager - Environment Variables Example
# Copy this file to .env and set your secure values
# NEVER commit .env to version control!

# ========================================
# DATABASE (REQUIRED)
# ========================================
# PostgreSQL password (minimum 16 characters recommended)
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD_MIN_16_CHARS

# ========================================
# SECURITY (PRODUCTION REQUIRED)
# ========================================
# Set to true when using HTTPS (required for production)
ALBAYAN_COOKIE_SECURE=true

# Allowed CORS origins (comma-separated)
# Example: ALBAYAN_CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALBAYAN_CORS_ORIGINS=https://yourdomain.com

# ========================================
# SESSION (OPTIONAL)
# ========================================
# Session duration in milliseconds (default: 8 hours)
# ALBAYAN_SESSION_MS=28800000

# ========================================
# RATE LIMITING (OPTIONAL)
# ========================================
# Redis URL for distributed rate limiting (optional)
# REDIS_URL=redis://localhost:6379

# ========================================
# ADVANCED (OPTIONAL)
# ========================================
# Debug mode (never enable in production!)
# ALBAYAN_DEBUG_MODE=false

# Optional: enable cross-origin isolation headers (COEP/COOP). Only enable if you understand the impact:
# It can break loading CDN assets unless every cross-origin resource is CORS-enabled.
# ALBAYAN_CROSS_ORIGIN_ISOLATION=false

# Origin secret header for additional security
# ALBAYAN_ORIGIN_SECRET=your-secret-key-here

# Bootstrap admin user (development only, NOT for production)
# ALBAYAN_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# ALBAYAN_BOOTSTRAP_ADMIN_PASSWORD=temporary-password
# ALBAYAN_BOOTSTRAP_ADMIN_NAME=Admin

# ========================================
# SETUP INSTRUCTIONS
# ========================================
# 1. Copy this file: cp env.example .env
# 2. Edit .env with your actual values
# 3. Use strong passwords (16+ characters, mixed case, numbers, symbols)
# 4. In production, ALWAYS set ALBAYAN_COOKIE_SECURE=true and use HTTPS
# 5. Set ALBAYAN_CORS_ORIGINS to your actual domain(s)

