# Copy this file to .env, then replace CHANGE_ME before starting Docker.
POSTGRES_PASSWORD=CHANGE_ME_USE_A_LONG_RANDOM_PASSWORD

# Local HTTP development defaults. Production HTTPS must use true.
ALBAYAN_COOKIE_SECURE=false
ALBAYAN_TRUST_PROXY_HEADERS=false
ALBAYAN_ENABLE_ONLINE_IMPORT=false

# Optional browser-based first-admin setup. Leave disabled unless you generate
# a long, private, one-time value and enter the same value in the setup screen.
# ALBAYAN_SETUP_TOKEN=CHANGE_ME_USE_A_DIFFERENT_LONG_RANDOM_TOKEN

# Safer alternative: create the first admin with the documented CLI command.
# ALBAYAN_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# ALBAYAN_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_USE_A_STRONG_ADMIN_PASSWORD
# ALBAYAN_BOOTSTRAP_ADMIN_NAME=Admin
