## Albayan production environment example

# REQUIRED: Postgres connection string
DATABASE_URL=postgresql+psycopg://albayan:CHANGE_ME@127.0.0.1:5432/albayan

# Alternative (recommended when the password contains URL punctuation): omit
# DATABASE_URL and provide these fields. The server escapes the password safely.
# ALBAYAN_DB_HOST=127.0.0.1
# ALBAYAN_DB_PORT=5432
# ALBAYAN_DB_NAME=albayan
# ALBAYAN_DB_USER=albayan
# ALBAYAN_DB_PASSWORD=p@ss%:/ word

# REQUIRED behind HTTPS (cookie must be Secure)
ALBAYAN_COOKIE_SECURE=true

# Optional (recommended if frontend is hosted on a different origin than the API):
# Comma-separated list of allowed origins.
# Example:
# ALBAYAN_CORS_ORIGINS=https://albayanhub.com,https://www.albayanhub.com
ALBAYAN_CORS_ORIGINS=https://albayanhub.com

# Enable only when the API is reachable exclusively through a trusted proxy
# that overwrites CF-Connecting-IP/X-Forwarded-For. Leave false for direct use.
ALBAYAN_TRUST_PROXY_HEADERS=false

# Maintenance only. Keep false while users can write data; prefer pg_restore
# or a tested offline restore procedure for production backups.
ALBAYAN_ENABLE_ONLINE_IMPORT=false

# Optional: enables the browser's one-time first-admin form. Generate a strong
# random value, enter the same value in the setup form, then remove this env.
# ALBAYAN_SETUP_TOKEN=replace-with-at-least-32-random-characters

# Session duration (8h)
ALBAYAN_SESSION_MS=28800000

# Login rate limit (per IP+email)
ALBAYAN_LOGIN_MAX_ATTEMPTS=20
ALBAYAN_LOGIN_WINDOW_MS=900000

# Optional: tune Postgres connection pooling for ECS/RDS sizing
# ALBAYAN_DB_POOL_SIZE=10
# ALBAYAN_DB_MAX_OVERFLOW=20
# ALBAYAN_DB_POOL_TIMEOUT=30
# ALBAYAN_DB_POOL_RECYCLE=3600

# Optional: if DATABASE_URL is not set, app will use SQLite
# ALBAYAN_DB_PATH=/var/lib/albayan/albayan.db
