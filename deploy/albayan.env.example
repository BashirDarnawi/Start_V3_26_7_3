## Albayan production environment example

# REQUIRED: Postgres connection string
DATABASE_URL=postgresql+psycopg://albayan:CHANGE_ME@127.0.0.1:5432/albayan

# REQUIRED behind HTTPS (cookie must be Secure)
ALBAYAN_COOKIE_SECURE=true

# Optional (recommended if frontend is hosted on a different origin than the API):
# Comma-separated list of allowed origins.
# Example:
# ALBAYAN_CORS_ORIGINS=https://albayanhub.com,https://www.albayanhub.com
ALBAYAN_CORS_ORIGINS=https://albayanhub.com

# Session duration (8h)
ALBAYAN_SESSION_MS=28800000

# Login rate limit (per IP+email)
ALBAYAN_LOGIN_MAX_ATTEMPTS=20
ALBAYAN_LOGIN_WINDOW_MS=900000

# Optional: tune Postgres connection pooling for ECS/RDS sizing
# ALBAYAN_DB_POOL_SIZE=10
# ALBAYAN_DB_MAX_OVERFLOW=20
# ALBAYAN_DB_POOL_TIMEOUT=30
# ALBAYAN_DB_POOL_RECYCLE=3600

# Optional: if DATABASE_URL is not set, app will use SQLite
# ALBAYAN_DB_PATH=/var/lib/albayan/albayan.db


